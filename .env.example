# Local development server port (default: 3000)
PORT=3000

# Firebase client config — copy public/firebase-applet-config.example.json
# to public/firebase-applet-config.json and fill in your values.
# Restrict the API key to your domain in Firebase Console → Project Settings → API keys.

# Razorpay (required for live payments — not yet wired server-side)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Admin email allowed to manage catalog (must match firestore.rules)
ADMIN_EMAIL=support@jalaramcomputers.com
