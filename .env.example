# Local development server port (default: 3000)
PORT=3000

# Public site URL (used in welcome email links)
SITE_URL=http://localhost:3000

# Shop contact details (welcome email footer)
SHOP_NAME=Jalaram Computers
SHOP_PHONE=9892848643
SHOP_EMAIL=jalaramcomputers21@gmail.com

# Newsletter / SMTP (Gmail example — use an App Password, not your login password)
# Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=jalaramcomputers21@gmail.com
SMTP_PASS=your_gmail_app_password_here
MAIL_FROM=jalaramcomputers21@gmail.com
MAIL_FROM_NAME=Jalaram Computers

# Firebase client config — copy public/firebase-applet-config.example.json
# to public/firebase-applet-config.json and fill in your values.
# Restrict the API key to your domain in Firebase Console → Project Settings → API keys.

# Razorpay (required for live payments — not yet wired server-side)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Admin email allowed to manage catalog (must match firestore.rules)
ADMIN_EMAIL=support@jalaramcomputers.com
