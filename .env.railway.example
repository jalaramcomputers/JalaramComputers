# Copy these into Railway → your web service → Variables
# DATABASE_URL is auto-injected when you add a PostgreSQL plugin and link it.

DEBUG=false
DJANGO_SECRET_KEY=generate-a-long-random-string-here

# Custom domain (required when using www.jalaramcomputers.com)
SITE_URL=https://www.jalaramcomputers.com
# ALLOWED_HOSTS is optional if SITE_URL is set — www + apex are added automatically
# ALLOWED_HOSTS=www.jalaramcomputers.com,jalaramcomputers.com,.railway.app

ADMIN_USERNAME=jcowner
ADMIN_EMAIL=jalaramcomputers21@gmail.com
ADMIN_PASSWORD=your-secure-password-here

# Google Sign-In (customer account page — /account)
# Create a Web OAuth client in Google Cloud Console; paste the Client ID here.
GOOGLE_OAUTH_CLIENT_ID=

# From Google Cloud → Credentials → your OAuth client → Client secret
GOOGLE_OAUTH_CLIENT_SECRET=

# Must match Google Console redirect URI exactly (defaults to SITE_URL + /account/google/callback/)
# GOOGLE_OAUTH_REDIRECT_URI=https://www.jalaramcomputers.com/account/google/callback/

SHOP_NAME=Jalaram Computers
SHOP_PHONE=9892848643
SHOP_EMAIL=jalaramcomputers21@gmail.com

# Product video upload (Cloudinary). REQUIRED for uploaded videos to survive
# redeploys — Railway's disk is wiped on each deploy. Sign up free at
# cloudinary.com → Dashboard → copy the API Environment variable.
# Use the single URL form (recommended) OR the three separate vars.
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Optional SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
