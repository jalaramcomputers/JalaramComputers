<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <% if (typeof heroPreload !== 'undefined' && heroPreload) { %>
  <link rel="preload" as="image" href="/assets/images/hero/instant_support.webp" fetchpriority="high" media="(min-width: 768px)">
  <link rel="preload" as="image" href="/assets/images/hero/instant_support_mobile.webp" fetchpriority="high" media="(max-width: 767px)">
  <link rel="preload" href="/data/hero-services.json" as="fetch" crossorigin>
  <% } %>
  <title><%= title %></title>
  <script src="/assets/js/tailwind.js"></script>
  <script src="/assets/js/iconify-icon.min.js" defer></script>
  <link href="/assets/css/fonts-base.css" rel="stylesheet">
  <link href="/assets/css/fonts-fast.css" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/design-system.css?v=1" id="jc-design-system">
  <link rel="stylesheet" href="/assets/css/navbar.css?v=4" id="jc-navbar">
  <link rel="stylesheet" href="/assets/css/minimal.css" id="jc-minimal">
  <link rel="stylesheet" href="/assets/css/mobile.css?v=10" id="jc-mobile">
  <link rel="stylesheet" href="/assets/css/glass.css?v=9" id="jc-glass">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="/assets/css/performance.css?v=2" id="jc-perf">
  <% if (typeof pageCss !== 'undefined' && pageCss) { pageCss.forEach(function(href) { %>
  <link rel="stylesheet" href="<%= href %>" id="jc-page-css">
  <% }); } %>
  <script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          primary: '#1A3A5C',
          'primary-dark': '#0F2640',
          'primary-deeper': '#091A2E',
          accent: '#D4AF37',
          silver: '#C0C0C0',
          'silver-light': '#E8E8E8',
          alabaster: '#F9F8F6',
          charcoal: '#1A1A1A',
          'warm-gray': '#6B7280',
        },
        fontFamily: {
          serif: ['Playfair Display', 'serif'],
          sans: ['Inter', 'sans-serif'],
        }
      }
    }
  }
  </script>
  <% if (typeof pageStyles !== 'undefined' && pageStyles) { %>
  <style><%- pageStyles %></style>
  <% } %>
  <script src="/assets/js/performance.js?v=1" defer id="jc-perf-js"></script>
  <script>(function(){try{if(!localStorage.getItem('jalaram_hero_cache_migrated_v8')){['v4','v5','v6','v7'].forEach(function(v){localStorage.removeItem('jalaram_hero_slides_'+v);});localStorage.setItem('jalaram_hero_cache_migrated_v8','1');}}catch(e){}})();</script>
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : 'bg-alabaster text-charcoal font-sans jc-site' %><%= activeNav === 'home' ? ' jc-landing' : '' %>">

  <%- include('partials/header') %>

  <%- body %>

  <%- include('partials/footer') %>

  <% if (typeof whatsappFloat !== 'undefined' && whatsappFloat) { %>
  <a id="whatsapp-float-btn" href="https://wa.me/919892848643" target="_blank" rel="noopener noreferrer"
     class="fixed bottom-6 right-6 z-50 w-12 h-12 bg-green-600 flex items-center justify-center text-white hover:bg-green-700 transition-colors shadow-lg" aria-label="Chat on WhatsApp">
    <iconify-icon icon="mdi:whatsapp" class="text-2xl"></iconify-icon>
  </a>
  <% } %>

  <script src="/assets/js/mobile-nav.js?v=3" id="jc-mobile-nav"></script>
  <script src="/assets/js/nav-search.js?v=2" defer id="jc-nav-search"></script>
  <script src="/assets/js/reveal.js?v=4" defer id="jc-reveal"></script>
  <% if (typeof pageScripts !== 'undefined' && pageScripts) { %>
  <%- pageScripts %>
  <% } %>
  <script type="module" src="/assets/js/cart-system.js" id="sd-interceptor"></script>
</body>
</html>
