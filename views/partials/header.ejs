<header id="site-header" class="jc-navbar sticky top-0 z-50">
  <div class="jc-navbar__rule" aria-hidden="true"></div>

  <div class="jc-navbar__inner max-w-7xl mx-auto px-5 sm:px-6 lg:px-8">
    <a id="nav-home-logo" href="/" class="jc-navbar__brand" aria-label="Jalaram Computers home">
      <img src="/assets/images/logo.png" alt="" class="jc-navbar__logo" width="140" height="48">
      <span class="jc-navbar__wordmark">
        <span class="jc-navbar__name">Jalaram</span>
        <span class="jc-navbar__tagline">Computers &amp; IT</span>
      </span>
    </a>

    <nav class="jc-navbar__nav hidden lg:flex" aria-label="Main navigation">
      <% navLinks.forEach(function(link) { %>
        <a id="<%= link.id %>" href="<%= link.href %>" class="<%= navClass(activeNav, link.key) %>">
          <span class="jc-nav-link__label"><%= link.label %></span>
        </a>
      <% }); %>
    </nav>

    <div id="header-actions" class="jc-navbar__actions">
      <div class="jc-navbar__search" id="header-search-wrap">
        <button type="button" id="header-search-toggle" class="jc-navbar__icon-btn" aria-label="Search products" aria-expanded="false" aria-controls="header-search">
          <iconify-icon icon="lucide:search" class="jc-navbar__icon"></iconify-icon>
        </button>
        <label class="jc-navbar__search-field" for="header-search">
          <span class="sr-only">Search products</span>
          <input
            type="search"
            id="header-search"
            class="search-input jc-navbar__search-input"
            placeholder="Search…"
            autocomplete="off"
            aria-label="Search products"
          >
        </label>
      </div>

      <a id="nav-cart-link" href="/cart" class="jc-navbar__icon-btn jc-navbar__cart" aria-label="Shopping cart">
        <iconify-icon icon="lucide:shopping-bag" class="jc-navbar__icon"></iconify-icon>
        <span class="jc-navbar__cart-count" aria-hidden="true">0</span>
      </a>

      <button type="button" id="mobile-menu-btn" class="jc-navbar__icon-btn jc-navbar__menu lg:hidden" aria-label="Open menu" aria-expanded="false">
        <iconify-icon icon="lucide:menu" class="jc-navbar__icon"></iconify-icon>
      </button>
    </div>
  </div>
</header>
