<script>
/* Home page behaviour — counters, scroll-stack nav, newsletter.
   The hero slideshow is driven by the shared cart-system.js engine
   (it binds to #hero-bg-layers / #hero-title / .hero-dot etc.). */
(function () {
  'use strict';

  /* ---- 1. Animated stat counters ---- */
  function countTo(el, end, suffix, decimals, duration) {
    if (!el || el.dataset.done) return;
    el.dataset.done = '1';
    var start = null;
    function step(ts) {
      if (!start) start = ts;
      var p = Math.min((ts - start) / duration, 1);
      var eased = p * (2 - p);
      el.textContent = (eased * end).toFixed(decimals) + suffix;
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = end.toFixed(decimals) + suffix;
    }
    requestAnimationFrame(step);
  }
  function runCounters() {
    countTo(document.getElementById('stat-uptime'), 99.9, '%', 1, 1600);
    countTo(document.getElementById('stat-nodes'), 12, 'K+', 0, 1800);
    countTo(document.getElementById('stat-projects'), 500, '+', 0, 2000);
  }

  /* ---- 2. Scroll-stack dot navigation (desktop) ---- */
  function initStackNav() {
    var dots = Array.prototype.slice.call(document.querySelectorAll('.jc-dots__dot'));
    var panels = document.querySelectorAll('.jc-panel');
    if (!dots.length || !panels.length) return;

    function onScroll() {
      var vh = window.innerHeight || document.documentElement.clientHeight || 1;
      var idx = Math.min(Math.round(window.scrollY / vh), panels.length - 1);
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === idx); });
    }
    dots.forEach(function (dot, i) {
      dot.addEventListener('click', function () {
        var vh = window.innerHeight || document.documentElement.clientHeight || 1;
        window.scrollTo({ top: i * vh, behavior: 'smooth' });
      });
    });
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  /* ---- 3. Newsletter (inline status, no page reload) ---- */
  function initNewsletter() {
    var form = document.getElementById('newsletter-form');
    var status = document.getElementById('newsletter-status');
    var btn = document.getElementById('newsletter-submit');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var email = (document.getElementById('newsletter-email') || {}).value || '';
      status.className = 'jc-news__status';
      if (!/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
        status.className = 'jc-news__status jc-news__status--error';
        status.textContent = 'Please enter a valid email address.';
        return;
      }
      if (btn) { btn.disabled = true; btn.textContent = 'Subscribing…'; }
      fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: email })
      }).then(function (r) { return r.json().catch(function () { return {}; }); })
        .then(function (data) {
          status.textContent = (data && data.message) || 'Thanks for subscribing!';
          form.reset();
        })
        .catch(function () {
          status.className = 'jc-news__status jc-news__status--error';
          status.textContent = 'Something went wrong. Please try again.';
        })
        .finally(function () { if (btn) { btn.disabled = false; btn.textContent = 'Subscribe'; } });
    });
  }

  /* ---- init ---- */
  function init() {
    runCounters();          // hero is in view on load
    initStackNav();
    initNewsletter();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
