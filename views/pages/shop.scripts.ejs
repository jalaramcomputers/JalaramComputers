<script> document.querySelectorAll('.filter-checkbox').forEach(cb => { cb.addEventListener('change', function() { const icon = this.parentElement.querySelector('.checked-icon'); if (this.checked) { icon.classList.remove('opacity-0', 'scale-50'); icon.classList.add('opacity-100', 'scale-100'); } else { icon.classList.add('opacity-0', 'scale-50'); icon.classList.remove('opacity-100', 'scale-100'); } }); });</script>