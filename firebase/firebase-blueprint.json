{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An IT or hardware product stored in Jalaram Computers catalog",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique URL-safe identifier for the product"
        },
        "name": {
          "type": "string",
          "description": "Display name of the product"
        },
        "brand": {
          "type": "string",
          "description": "Brand of the product"
        },
        "category": {
          "type": "string",
          "description": "Category classification"
        },
        "price": {
          "type": "number",
          "description": "Regular selling price of the product in INR"
        },
        "originalPrice": {
          "type": "number",
          "description": "Pre-discount value"
        },
        "rating": {
          "type": "number",
          "description": "Rating score out of 5"
        },
        "ratingCount": {
          "type": "number",
          "description": "Number of product reviews"
        },
        "badge": {
          "type": "string",
          "description": "Tag badge like New, Premium, Bestseller"
        },
        "details": {
          "type": "string",
          "description": "Specifications or short description text"
        },
        "imageIcon": {
          "type": "string",
          "description": "Lucide icon symbol name"
        }
      },
      "required": ["id", "name", "brand", "category", "price"]
    },
    "Category": {
      "title": "Category",
      "description": "A classification category for products",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique URL-safe category identifier"
        },
        "name": {
          "type": "string",
          "description": "Display name of the category"
        }
      },
      "required": ["id", "name"]
    },
    "Order": {
      "title": "Order",
      "description": "An ecommerce hardware and services purchase order",
      "type": "object",
      "properties": {
        "orderId": {
          "type": "string"
        },
        "date": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "subtotal": {
          "type": "number"
        },
        "discount": {
          "type": "number"
        },
        "gst": {
          "type": "number"
        },
        "total": {
          "type": "number"
        },
        "userId": {
          "type": "string"
        },
        "customer": {
          "type": "object"
        },
        "items": {
          "type": "array"
        }
      },
      "required": ["orderId", "date", "status", "total", "customer", "items"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Collection of all products in Jalaram Computers catalog"
    },
    "/categories/{categoryId}": {
      "schema": {
        "$ref": "#/entities/Category"
      },
      "description": "List of available product categories"
    },
    "/orders/{orderId}": {
      "schema": {
        "$ref": "#/entities/Order"
      },
      "description": "Customer hardware and services transaction orders"
    }
  }
}
